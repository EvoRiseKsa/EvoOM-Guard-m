{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:evoguard:release-source-finalizer-handoff:1",
  "title": "EvoGuard unsigned release-source handoff v1",
  "description": "Untrusted canonical handoff; a privileged finalizer must independently match every field before signing.",
  "type": "object",
  "required": ["format", "source", "context", "record"],
  "properties": {
    "format": { "const": "EVOGUARD_RELEASE_SOURCE_FINALIZER_HANDOFF_V1" },
    "source": {
      "type": "object",
      "required": ["repository", "repository_id", "default_branch", "workflow_run_id", "workflow_run_attempt", "protected_ref", "target_commit_sha", "target_tree_sha"],
      "properties": {
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,38})/[A-Za-z0-9_.-]{1,100}$", "maxLength": 512 },
        "repository_id": { "$ref": "#/$defs/numericId" },
        "default_branch": { "const": "main" },
        "workflow_run_id": { "$ref": "#/$defs/numericId" },
        "workflow_run_attempt": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "protected_ref": { "const": "refs/heads/main" },
        "target_commit_sha": { "$ref": "#/$defs/gitDigest" },
        "target_tree_sha": { "$ref": "#/$defs/gitDigest" }
      },
      "additionalProperties": false
    },
    "context": { "$ref": "#/$defs/releaseSourceContext" },
    "record": {
      "type": "object",
      "required": ["sha256", "size"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 1, "maximum": 8388608 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "releaseSourceContext": {
      "type": "object",
      "required": [
        "format",
        "repository",
        "repository_id",
        "run_id",
        "run_attempt",
        "protected_ref",
        "target_commit_sha",
        "target_tree_sha",
        "parent_commit_sha",
        "parent_tree_sha",
        "candidate_sha256",
        "policy_sha256",
        "verifier_pack_sha256"
      ],
      "properties": {
        "format": { "const": "EVOGUARD_RELEASE_SOURCE_CONTEXT_V1" },
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,38})/[A-Za-z0-9_.-]{1,100}$", "maxLength": 512 },
        "repository_id": { "$ref": "#/$defs/numericId" },
        "run_id": { "$ref": "#/$defs/numericId" },
        "run_attempt": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "protected_ref": { "const": "refs/heads/main" },
        "target_commit_sha": { "$ref": "#/$defs/gitDigest" },
        "target_tree_sha": { "$ref": "#/$defs/gitDigest" },
        "parent_commit_sha": { "$ref": "#/$defs/gitDigest" },
        "parent_tree_sha": { "$ref": "#/$defs/gitDigest" },
        "candidate_sha256": { "$ref": "#/$defs/sha256" },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "verifier_pack_sha256": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "numericId": { "type": "string", "pattern": "^[1-9][0-9]{0,255}$" },
    "gitDigest": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
