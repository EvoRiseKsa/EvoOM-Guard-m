{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:evoguard:release-source-admission:2",
  "title": "EvoGuard release-source admission v2",
  "description": "Canonical signed ALLOW manifest created only after exact local/raw-Git producer-receipt verification and a fresh GitHub Artifact Attestation verification. Its signing key, purpose, domain, and format are distinct from all V1 and artifact-admission contracts.",
  "type": "object",
  "required": [
    "format", "decision", "source", "context", "producer", "admitter", "bootstrap",
    "execution", "replay", "record", "handoff", "producer_receipt",
    "provider", "toolchain", "key_separation", "authentication"
  ],
  "properties": {
    "format": { "const": "EVOGUARD_RELEASE_SOURCE_ADMISSION_V2" },
    "decision": { "const": "ALLOW" },
    "source": { "$ref": "#/$defs/source" },
    "context": { "$ref": "#/$defs/context" },
    "producer": { "$ref": "#/$defs/producer" },
    "admitter": { "$ref": "#/$defs/producer" },
    "bootstrap": {
      "type": "object",
      "required": ["runtime_identity_format", "guard_artifact_sha256"],
      "properties": {
        "runtime_identity_format": { "const": "EVOGUARD_GUARD_ZIPAPP_SHA256_V1" },
        "guard_artifact_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "outcome", "guard_exit_code", "candidate_isolation", "network",
        "report_integrity", "overall_profile"
      ],
      "properties": {
        "outcome": { "const": "PASS" },
        "guard_exit_code": { "const": 0 },
        "candidate_isolation": { "enum": ["docker", "gvisor"] },
        "network": { "const": "none" },
        "report_integrity": { "const": "external_process_isolated" },
        "overall_profile": { "const": "black_box_external_judge" }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "required": ["evaluation", "producer", "trigger", "admitter"],
      "properties": {
        "evaluation": { "$ref": "#/$defs/run" },
        "producer": { "$ref": "#/$defs/run" },
        "trigger": { "$ref": "#/$defs/run" },
        "admitter": { "$ref": "#/$defs/run" }
      },
      "additionalProperties": false
    },
    "record": {
      "allOf": [
        { "$ref": "#/$defs/descriptor" },
        { "properties": { "path": { "const": "record/verdict.json" }, "size": { "maximum": 8388608 } } }
      ]
    },
    "handoff": {
      "allOf": [
        { "$ref": "#/$defs/descriptor" },
        { "properties": { "path": { "const": "materials/release-source-handoff.json" }, "size": { "maximum": 524288 } } }
      ]
    },
    "producer_receipt": {
      "allOf": [
        { "$ref": "#/$defs/descriptor" },
        { "properties": { "path": { "const": "materials/producer-receipt.json" }, "size": { "maximum": 524288 } } }
      ]
    },
    "provider": {
      "type": "object",
      "required": [
        "name", "artifact", "policy", "verified_attestation_count", "receipt", "raw_output"
      ],
      "properties": {
        "name": { "const": "github-artifact-attestations" },
        "artifact": { "$ref": "#/$defs/byteDescriptor" },
        "policy": { "$ref": "#/$defs/githubPolicy" },
        "verified_attestation_count": { "const": 1 },
        "receipt": {
          "allOf": [
            { "$ref": "#/$defs/descriptor" },
            { "properties": { "path": { "const": "provider/github-attestation-receipt.json" }, "size": { "maximum": 65536 } } }
          ]
        },
        "raw_output": {
          "allOf": [
            { "$ref": "#/$defs/descriptor" },
            { "properties": { "path": { "const": "provider/github-attestation-output.json" }, "size": { "minimum": 2, "maximum": 4194304 } } }
          ]
        }
      },
      "additionalProperties": false
    },
    "toolchain": {
      "type": "object",
      "required": ["git", "github_cli", "provider_isolation"],
      "properties": {
        "git": { "$ref": "#/$defs/toolPin" },
        "github_cli": { "$ref": "#/$defs/toolPin" },
        "provider_isolation": {
          "type": "object",
          "required": ["platform", "uid", "gid"],
          "properties": {
            "platform": { "const": "posix" },
            "uid": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
            "gid": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "key_separation": {
      "type": "object",
      "required": [
        "trusted_finalizer", "artifact_admission_v1",
        "artifact_digest_admission_v2", "release_source_finalizer_v1"
      ],
      "properties": {
        "trusted_finalizer": { "$ref": "#/$defs/keyId" },
        "artifact_admission_v1": { "$ref": "#/$defs/keyId" },
        "artifact_digest_admission_v2": { "$ref": "#/$defs/keyId" },
        "release_source_finalizer_v1": { "$ref": "#/$defs/keyId" }
      },
      "additionalProperties": false
    },
    "authentication": {
      "type": "object",
      "required": ["algorithm", "key_id", "purpose", "key_domain", "signature_path"],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "key_id": { "$ref": "#/$defs/keyId" },
        "purpose": { "const": "evoguard-release-source-admission-v2" },
        "key_domain": { "const": "release-source-admission-v2" },
        "signature_path": { "const": "admission.sig" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitDigest": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
    "keyId": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "toolPin": {
      "type": "object",
      "required": ["sha256"],
      "properties": { "sha256": { "$ref": "#/$defs/sha256" } },
      "additionalProperties": false
    },
    "numericId": { "type": "string", "pattern": "^[1-9][0-9]{0,255}$" },
    "runAttempt": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,38})/[A-Za-z0-9_.-]{1,100}$",
      "maxLength": 512
    },
    "run": {
      "type": "object",
      "required": ["run_id", "run_attempt"],
      "properties": {
        "run_id": { "$ref": "#/$defs/numericId" },
        "run_attempt": { "$ref": "#/$defs/runAttempt" }
      },
      "additionalProperties": false
    },
    "byteDescriptor": {
      "type": "object",
      "required": ["sha256", "size"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 1, "maximum": 524288 }
      },
      "additionalProperties": false
    },
    "descriptor": {
      "type": "object",
      "required": ["path", "sha256", "size"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 256 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 1, "maximum": 8388608 }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "repository", "repository_id", "default_branch", "workflow_run_id",
        "workflow_run_attempt", "protected_ref", "target_commit_sha", "target_tree_sha"
      ],
      "properties": {
        "repository": { "$ref": "#/$defs/repository" },
        "repository_id": { "$ref": "#/$defs/numericId" },
        "default_branch": { "const": "main" },
        "workflow_run_id": { "$ref": "#/$defs/numericId" },
        "workflow_run_attempt": { "$ref": "#/$defs/runAttempt" },
        "protected_ref": { "const": "refs/heads/main" },
        "target_commit_sha": { "$ref": "#/$defs/gitDigest" },
        "target_tree_sha": { "$ref": "#/$defs/gitDigest" }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": [
        "format", "repository", "repository_id", "run_id", "run_attempt", "protected_ref",
        "target_commit_sha", "target_tree_sha", "parent_commit_sha", "parent_tree_sha",
        "candidate_sha256", "policy_sha256", "verifier_pack_sha256"
      ],
      "properties": {
        "format": { "const": "EVOGUARD_RELEASE_SOURCE_CONTEXT_V1" },
        "repository": { "$ref": "#/$defs/repository" },
        "repository_id": { "$ref": "#/$defs/numericId" },
        "run_id": { "$ref": "#/$defs/numericId" },
        "run_attempt": { "$ref": "#/$defs/runAttempt" },
        "protected_ref": { "const": "refs/heads/main" },
        "target_commit_sha": { "$ref": "#/$defs/gitDigest" },
        "target_tree_sha": { "$ref": "#/$defs/gitDigest" },
        "parent_commit_sha": { "$ref": "#/$defs/gitDigest" },
        "parent_tree_sha": { "$ref": "#/$defs/gitDigest" },
        "candidate_sha256": { "$ref": "#/$defs/sha256" },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "verifier_pack_sha256": {
          "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    },
    "producer": {
      "type": "object",
      "required": [
        "workflow_repository", "workflow_repository_id", "workflow_id", "workflow_path",
        "workflow_blob_sha", "workflow_run_id", "workflow_run_attempt", "workflow_event",
        "workflow_ref", "workflow_commit_sha", "trigger_workflow_id", "trigger_workflow_path",
        "trigger_workflow_blob_sha", "trigger_workflow_run_id", "trigger_workflow_run_attempt",
        "runner_class"
      ],
      "properties": {
        "workflow_repository": { "$ref": "#/$defs/repository" },
        "workflow_repository_id": { "$ref": "#/$defs/numericId" },
        "workflow_id": { "$ref": "#/$defs/numericId" },
        "workflow_path": { "$ref": "#/$defs/workflowPath" },
        "workflow_blob_sha": { "$ref": "#/$defs/gitDigest" },
        "workflow_run_id": { "$ref": "#/$defs/numericId" },
        "workflow_run_attempt": { "$ref": "#/$defs/runAttempt" },
        "workflow_event": { "const": "workflow_run" },
        "workflow_ref": { "const": "refs/heads/main" },
        "workflow_commit_sha": { "$ref": "#/$defs/gitDigest" },
        "trigger_workflow_id": { "$ref": "#/$defs/numericId" },
        "trigger_workflow_path": { "$ref": "#/$defs/workflowPath" },
        "trigger_workflow_blob_sha": { "$ref": "#/$defs/gitDigest" },
        "trigger_workflow_run_id": { "$ref": "#/$defs/numericId" },
        "trigger_workflow_run_attempt": { "$ref": "#/$defs/runAttempt" },
        "runner_class": { "const": "github-hosted" }
      },
      "additionalProperties": false
    },
    "workflowPath": {
      "type": "string",
      "pattern": "^\\.github/workflows/[A-Za-z0-9][A-Za-z0-9_.-]*\\.ya?ml$",
      "maxLength": 256
    },
    "githubPolicy": {
      "type": "object",
      "required": [
        "repository", "signer_workflow", "signer_digest", "source_ref", "source_digest",
        "cert_oidc_issuer", "predicate_type", "deny_self_hosted_runners", "attestation_limit"
      ],
      "properties": {
        "repository": { "$ref": "#/$defs/repository" },
        "signer_workflow": {
          "type": "string",
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,38})/[A-Za-z0-9_.-]{1,100}/\\.github/workflows/[A-Za-z0-9][A-Za-z0-9_.-]*\\.ya?ml$",
          "maxLength": 768
        },
        "signer_digest": { "$ref": "#/$defs/gitDigest" },
        "source_ref": { "const": "refs/heads/main" },
        "source_digest": { "$ref": "#/$defs/gitDigest" },
        "cert_oidc_issuer": { "const": "https://token.actions.githubusercontent.com" },
        "predicate_type": { "const": "https://slsa.dev/provenance/v1" },
        "deny_self_hosted_runners": { "const": true },
        "attestation_limit": { "const": 1 }
      },
      "additionalProperties": false
    }
  }
}
